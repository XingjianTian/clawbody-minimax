# LLM Configuration (Alibaba Cloud DashScope, OpenAI-compatible API)
# These variable names are retained for compatibility with the application.
MINIMAX_API_KEY=your-dashscope-api-key
MINIMAX_MODEL=qwen-plus
MINIMAX_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MINIMAX_MAX_TOKENS=80
HTTP_TRUST_ENV=false

# OpenClaw Gateway Configuration
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
OPENCLAW_TOKEN=
OPENCLAW_AGENT_ID=main
OPENCLAW_SESSION_KEY=main

# Baidu Smart Cloud ASR/TTS Configuration
BAIDU_APP_ID=your-baidu-app-id
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key
BAIDU_TTS_PER=111
BAIDU_TTS_SPD=5
BAIDU_TTS_PIT=5
BAIDU_TTS_VOL=12
BAIDU_ASR_LANGUAGE=zh-CN

# Robot Connection
ROBOT_HOST=localhost
ROBOT_PORT=8000
ROBOT_IDENTITY_FILE=robot_identity/AGENTS.md

# Feature Flags
ENABLE_FACE_TRACKING=true
HEAD_TRACKER_TYPE=yolo
ENABLE_LOCAL_VISION=false
ENABLE_LLM_TOOLS=false
ENABLE_AUTO_MOTION=true

# Private service consumed by PsyTwin Sentinel (do not publish this port)
SERVICE_HOST=127.0.0.1
SERVICE_PORT=7860
SERVICE_API_KEY=replace-with-a-long-random-value

# Windows-only Reachy Mini Lite Host Bridge (localhost only)
HOST_BRIDGE_HOST=127.0.0.1
HOST_BRIDGE_PORT=7861
HOST_BRIDGE_API_KEY=replace-with-a-long-random-value
HOST_BRIDGE_DAEMON_URL=http://127.0.0.1:8000
HOST_BRIDGE_CLAWBODY_HEALTH_URL=http://127.0.0.1:7860/health
